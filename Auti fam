-- [[ VUKHOA V32 PRO - STABLE FARM ]] --

local Library = loadstring(game:HttpGet("https://raw.githubusercontent.com/xHeptc/Kavo-UI-Library/main/source.lua"))()
-- Midnight theme, Menu có thể nắm kéo đầu trang để di chuyển
local Window = Library.CreateLib("VuKhoa V32 - Stable Farm", "Midnight")

-- [[ SETTINGS ]] --
_G.AutoFarm = false
_G.BringMob = false
_G.AutoClick = false
_G.Distance = 9 -- Khoảng cách trên đầu quái (Số vàng để không bị văng)

-- [[ TABS ]] --
local Main = Window:NewTab("Main Farm")
local Section = Main:NewSection("Haunted Castle (Bone)")

-- [[ TOGGLES ]] --

Section:NewToggle("Auto Farm Bone", "Tele trên đầu quái & Không văng", function(state)
    _G.AutoFarm = state
    -- Khóa Camera khi farm để không bị rối
    if state then
        workspace.CurrentCamera.CameraSubject = game.Players.LocalPlayer.Character.Humanoid
    end
end)

Section:NewToggle("Smart Bring", "Gom quái không lag camera", function(state)
    _G.BringMob = state
end)

Section:NewToggle("Auto Click", "Tự động đánh", function(state)
    _G.AutoClick = state
end)

-- [[ LOGIC XỬ LÝ CHÍNH ]] --

task.spawn(function()
    while task.wait() do
        if _G.AutoFarm then
            pcall(function()
                local lp = game.Players.LocalPlayer
                local char = lp.Character
                if not char or not char:FindFirstChild("HumanoidRootPart") then return end
                local hrp = char.HumanoidRootPart
                
                -- Ngăn nhân vật bị rơi hoặc văng do vật lý
                if not hrp:FindFirstChild("VuKhoa_Velocity_Fix") then
                    local bv = Instance.new("BodyVelocity")
                    bv.Name = "VuKhoa_Velocity_Fix"
                    bv.Velocity = Vector3.new(0, 0, 0)
                    bv.MaxForce = Vector3.new(9e9, 9e9, 9e9)
                    bv.Parent = hrp
                end

                -- Kiểm tra Quest
                if not lp.PlayerGui.Main.Quest.Visible then
                    hrp.CFrame = CFrame.new(-9515, 164, 5786) -- NPC Bone
                    task.wait(0.3)
                    game:GetService("ReplicatedStorage").Remotes.CommF_:InvokeServer("StartQuest", "HauntedQuest1", 1)
                else
                    -- Tìm quái
                    for _, v in pairs(workspace.Enemies:GetChildren()) do
                        if v.Name == "Reborn Skeleton" and v:FindFirstChild("Humanoid") and v.Humanoid.Health > 0 then
                            -- GIỮ CAMERA ỔN ĐỊNH: Không cho Camera xoay theo quái
                            workspace.CurrentCamera.CFrame = CFrame.new(workspace.CurrentCamera.CFrame.Position, hrp.Position)
                            
                            -- Đứng trên đầu quái 9 studs (Khoảng cách an toàn nhất Sea 3)
                            hrp.CFrame = v.HumanoidRootPart.CFrame * CFrame.new(0, _G.Distance, 0) * CFrame.Angles(math.rad(-90), 0, 0)
                            
                            -- Bring Mob
                            if _G.BringMob then
                                for _, m in pairs(workspace.Enemies:GetChildren()) do
                                    if m.Name == "Reborn Skeleton" and m:FindFirstChild("HumanoidRootPart") then
                                        m.HumanoidRootPart.CFrame = hrp.CFrame * CFrame.new(0, -_G.Distance - 2, 0)
                                        m.HumanoidRootPart.CanCollide = false
                                        m.Humanoid.PlatformStand = true
                                    end
                                end
                            end
                            break
                        end
                    end
                end
            end)
        else
            -- Xóa BodyVelocity khi tắt farm để di chuyển bình thường
            if game.Players.LocalPlayer.Character.HumanoidRootPart:FindFirstChild("VuKhoa_Velocity_Fix") then
                game.Players.LocalPlayer.Character.HumanoidRootPart.VuKhoa_Velocity_Fix:Destroy()
            end
        end
    end
end)

-- AUTO CLICK
task.spawn(function()
    while task.wait(0.1) do
        if _G.AutoClick and _G.AutoFarm then
            game:GetService("VirtualUser"):CaptureController()
            game:GetService("VirtualUser"):ClickButton1(Vector2.new(0,0))
        end
    end
end)
