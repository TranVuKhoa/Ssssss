local Library = loadstring(game:HttpGet("https://raw.githubusercontent.com/xHeptc/Kavo-UI-Library/main/source.lua"))()
local Window = Library.CreateLib("VuKhoa V32 Pro - Haunted Castle", "Midnight")

-- [[ SETTINGS ]] --
_G.AutoFarmBone = false
_G.BringMob = false
_G.AutoClick = false
_G.FastAttack = false

-- [[ TABS ]] --
local Main = Window:NewTab("Auto Farm")
local FarmSection = Main:NewSection("Farm Bone (Sea 3)")

-- [[ FUNCTIONS ]] --
function GetQuest()
    local args = {[1] = "StartQuest", [2] = "HauntedQuest1", [3] = 1}
    game:GetService("ReplicatedStorage").Remotes.CommF_:InvokeServer(unpack(args))
end

-- [[ UI ELEMENTS ]] --
FarmSection:NewToggle("Auto Farm Bone", "Tự động bay về đảo và farm", function(state)
    _G.AutoFarmBone = state
end)

FarmSection:NewToggle("Bring Mob (Safe Mode)", "Gom quái thông minh (Chống chết)", function(state)
    _G.BringMob = state
end)

FarmSection:NewToggle("Auto Click & Fast Attack", "Tự động vung kiếm", function(state)
    _G.AutoClick = state
    _G.FastAttack = state
end)

local Misc = Window:NewTab("Misc")
local MiscSection = Misc:NewSection("Utilities")
MiscSection:NewButton("Reset Character", "Tự tử", function()
    game.Players.LocalPlayer.Character:BreakJoints()
end)

-- [[ LOGIC CHÍNH ]] --
task.spawn(function()
    while task.wait() do
        if _G.AutoFarmBone then
            pcall(function()
                local player = game.Players.LocalPlayer
                local character = player.Character
                if not character or not character:FindFirstChild("HumanoidRootPart") then return end
                
                local hrp = character.HumanoidRootPart
                local questPos = CFrame.new(-9515, 164, 5786) -- Tọa độ NPC Quest
                
                -- 1. Nếu chưa có nhiệm vụ: Bay về NPC nhận Quest
                if not player.PlayerGui.Main.Quest.Visible then
                    if (hrp.Position - questPos.Position).Magnitude > 50 then
                        hrp.CFrame = questPos -- Teleport thẳng về NPC
                    end
                    task.wait(0.5)
                    GetQuest()
                else
                    -- 2. Đã có nhiệm vụ: Tìm quái Skeleton
                    local foundMob = false
                    for _, v in pairs(workspace.Enemies:GetChildren()) do
                        if v.Name == "Reborn Skeleton" and v:FindFirstChild("Humanoid") and v.Humanoid.Health > 0 then
                            foundMob = true
                            local mobHRP = v.HumanoidRootPart
                            
                            -- Khoảng cách an toàn dựa trên việc có đang đánh hay không
                            -- Nếu đang đánh: Hút lại 5 studs. Nếu không đánh: Đẩy ra 15 studs
                            local dist = (_G.AutoClick or _G.FastAttack) and 5 or 15
                            
                            -- Nhân vật lơ lửng trên đầu quái để ổn định
                            hrp.CFrame = mobHRP.CFrame * CFrame.new(0, 10, 0)
                            
                            -- Gom quái (Bring Mob) theo kiểu dìm xuống đất và ngửa mặt
                            if _G.BringMob then
                                for _, m in pairs(workspace.Enemies:GetChildren()) do
                                    if m.Name == "Reborn Skeleton" and m:FindFirstChild("HumanoidRootPart") then
                                        m.HumanoidRootPart.CanCollide = false
                                        m.Humanoid.PlatformStand = true
                                        -- Đưa quái về trước mặt, dìm xuống đất, ngửa mặt lên trời
                                        m.HumanoidRootPart.CFrame = hrp.CFrame * CFrame.new(0, -14, -dist) * CFrame.Angles(math.rad(90), 0, 0)
                                        m.HumanoidRootPart.Size = Vector3.new(20, 20, 20)
                                    end
                                end
                            end
                            break
                        end
                    end
                    
                    -- Nếu không thấy quái ở gần, bay về bãi quái trung tâm
                    if not foundMob then
                        hrp.CFrame = CFrame.new(-9500, 170, 6000) 
                    end
                end
            end)
        end
    end
end)

-- LOGIC AUTO CLICK
task.spawn(function()
    while task.wait(0.1) do
        if _G.AutoClick and _G.AutoFarmBone then
            local VirtualUser = game:GetService("VirtualUser")
            VirtualUser:CaptureController()
            VirtualUser:ClickButton1(Vector2.new(0,0))
            if _G.FastAttack then
                game:GetService("ReplicatedStorage").RigControllerEvent:FireServer("WeaponAttack")
            end
        end
    end
end)
