        Content.Visible = isOpen
        MainFrame.Size = isOpen and UDim2.new(0, 280, 0, 500) or UDim2.new(0, 280, 0, 50)
        ToggleBtn.Text = isOpen and "▼" or "▶"
        ToggleBtn.BackgroundColor3 = isOpen and Color3.fromRGB(255, 100, 100) or Color3.fromRGB(100, 180, 255)
    end
end)

