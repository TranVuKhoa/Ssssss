-- ===== GAME LOGIC =====
runService.Heartbeat:Connect(function(dt)
    local char = lp.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return end
    local root = char.HumanoidRootPart
    
    -- Xray ESP
    if xrayActive then
        for _, p in pairs(game.Players:GetPlayers()) do
            if p ~= lp and p.Character then
                if not p.Character:FindFirstChild("TrVuKhoaa_ESP") then
                    local h = Instance.new("Highlight", p.Character)
                    h.Name = "TrVuKhoaa_ESP"
                    h.FillColor = Color3.new(1, 0, 0)
                end
            end
        end
    else
        for _, p in pairs(game.Players:GetPlayers()) do 
            if p.Character and p.Character:FindFirstChild("TrVuKhoaa_ESP") then 
                p.Character.TrVuKhoaa_ESP:Destroy() 
            end 
        end
    end
    
    -- Movement
    local target = (ghostActive and ghostModel) and ghostModel:FindFirstChild("HumanoidRootPart") or root
    
    if localMoveDir.Magnitude > 0 then
        -- Disable collision
        for _, v in pairs(char:GetDescendants()) do 
            if v:IsA("BasePart") then v.CanCollide = false end 
        end
        if ghostModel then 
            for _, v in pairs(ghostModel:GetDescendants()) do 
                if v:IsA("BasePart") then v.CanCollide = false end 
            end 
        end
        
        -- Move
        local moveVec = (target.CFrame.LookVector * -localMoveDir.Z) + (target.CFrame.RightVector * localMoveDir.X) + (Vector3.new(0,1,0) * localMoveDir.Y)
        target.CFrame = target.CFrame + (moveVec.Unit * (currentSpeed * 50 * dt))
        
        if ghimActive and not ghostActive then 
            lockedPos = target.CFrame 
        end
    end
    
    -- Ghim Pos
    if ghimActive and lockedPos and not ghostActive then 
        root.CFrame = lockedPos
        root.Velocity = Vector3.new(0,0,0) 
    end
    
    -- Ghost Mode
    if ghostActive and lockedPos then 
        root.CFrame = lockedPos or root.CFrame
        root.Velocity = Vector3.new(0,0,0) 
    end
    
    -- Air Walk
    if airWalkActive and airWalkPart then 
        airWalkPart.Position = target.Position - Vector3.new(0, 3.5, 0) 
    end
end)
